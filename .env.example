# ── Urreal3D Environment Variables ──
# Copy this file to .env and fill in your real values

# Server
PORT=3001
FRONTEND_URL=https://urreal3d.com

# Email (Gmail example — use App Password, not your real password)
# To get Gmail App Password: Google Account > Security > 2FA > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Where notification emails go (your email)
OWNER_EMAIL=stephen@urreal3d.com

# Admin key to view all inquiries at GET /api/inquiries
# Change this to any strong random string
ADMIN_KEY=change-this-to-something-secret-123
